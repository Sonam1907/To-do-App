# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/todo_app_dev?schema=public"

# Random secret for signing Auth.js session tokens (generate with: openssl rand -base64 32)
AUTH_SECRET=""

# Random secret that authenticates requests to the reminder cron endpoint
# (generate with: openssl rand -hex 32)
CRON_SECRET=""

# Resend API key for sending reminder emails (https://resend.com/api-keys)
RESEND_API_KEY=""

# Sender address for reminder emails. Resend's sandbox address only delivers
# to the email you signed up to Resend with, until you verify a custom domain.
REMINDER_FROM_EMAIL="onboarding@resend.dev"
